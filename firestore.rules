rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null;
    }

    // Rules for public forms submissions
    match /eventRegistrations/{id} {
      allow read: if isAdmin();
      allow create: if true;
      allow update, delete: if isAdmin();
    }
    
    match /volunteers/{id} {
      allow read: if isAdmin();
      allow create: if true;
      allow update, delete: if isAdmin();
    }
    
    match /contactMessages/{id} {
      allow read: if isAdmin();
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    // Rules for standard admin-managed content (read by anyone, write by active admins)
    match /{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
